{
  "skipDangerousModePermissionPrompt": true,
  "env": {
    "CLAUDE_CODE_MAX_OUTPUT_TOKENS": "32000",
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "60"
  },
  "permissions": {
    "defaultMode": "bypassPermissions",
    "additionalDirectories": [".tmp", ".claude"],
    "deny": [
      "Read(.env)",
      "Read(.env.development)",
      "Read(.env.staging)",
      "Read(.env.production)",
      "Read(.env.local)",
      "Edit(.env)",
      "Edit(.env.development)",
      "Edit(.env.staging)",
      "Edit(.env.production)",
      "Edit(.env.local)",
      "Read(**/*.jks)",
      "Read(**/*.keystore)",
      "Read(**/*.p12)",
      "Read(**/*.cer)",
      "Read(**/*.mobileprovision)",
      "Read(**/*.provisionprofile)",
      "Read(**/key.properties)",
      "Read(**/keystore.properties)",
      "Read(**/local.properties)",
      "Read(**/GoogleService-Info.plist)",
      "Read(**/google-services.json)",
      "Read(**/firebase-credentials.json)",
      "Read(**/sentry-auth-token)",
      "Edit(**/*.jks)",
      "Edit(**/*.keystore)",
      "Edit(**/*.p12)",
      "Edit(**/key.properties)",
      "Edit(**/keystore.properties)",
      "Edit(**/GoogleService-Info.plist)",
      "Edit(**/google-services.json)",
      "Edit(**/firebase-credentials.json)"
    ],
    "allow": [
      "TodoWrite",
      "TodoRead",
      "ToolSearch",
      "WebFetch",
      "WebSearch",
      "Agent",
      "Skill",
      "Monitor",
      "ScheduleWakeup",
      "PushNotification",
      "AskUserQuestion",
      "CronCreate",
      "CronDelete",
      "CronList",
      "Bash",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(pnpm *)",
      "Bash(yarn *)",
      "Bash(node *)",
      "Bash(expo *)",
      "Bash(eas *)",
      "Bash(tsc *)",
      "Bash(jest *)",
      "Bash(eslint *)",
      "Bash(prettier *)",
      "Bash(plop *)",
      "Bash(maestro *)",
      "Bash(detox *)",
      "Bash(pod *)",
      "Bash(xcodebuild *)",
      "Bash(xcrun *)",
      "Bash(adb *)",
      "Bash(emulator *)",
      "Bash(swift *)",
      "Bash(gradle *)",
      "Bash(./gradlew *)",
      "Bash(caffeinate *)",
      "Bash(mktemp *)",
      "Bash(mkdir *)",
      "Bash(touch *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(ln *)",
      "Bash(rm *)",
      "Bash(rmdir *)",
      "Bash(tee *)",
      "Bash(chmod *)",
      "Bash(kill *)",
      "Bash(pkill *)",
      "Bash(open *)",
      "Bash(python3 *)",
      "Bash(perl *)",
      "Bash(bash *)",
      "Bash(sh *)",
      "Bash(sed *)",
      "Bash(awk *)",
      "Bash(xargs *)",
      "Bash(jq *)",
      "Bash(yq *)",
      "Bash(curl *)",
      "Bash(base64 *)",
      "Bash(nc *)",
      "Bash(zip *)",
      "Bash(unzip *)",
      "Bash(tar *)",
      "Bash(grep *)",
      "Bash(find *)",
      "Bash(git *)",
      "Bash(gh *)",
      "Bash(cat *)",
      "Bash(ls *)",
      "Bash(echo *)",
      "Bash(which *)",
      "Bash(wc *)",
      "Bash(sort *)",
      "Bash(uniq *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(diff *)",
      "Bash(env *)",
      "Bash(printenv *)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/session-start.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/session-init.cjs",
            "_origin": "engineer"
          }
        ]
      },
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/usage-quota-cache-refresh.cjs",
            "timeout": 8,
            "_origin": "engineer"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"hookSpecificOutput\":{\"hookEventName\":\"PermissionRequest\",\"permissionDecision\":\"allow\",\"permissionDecisionReason\":\"Auto-approved\"}}'",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/check-dangerous-bash.sh"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/descriptive-name.cjs",
            "_origin": "engineer"
          }
        ]
      },
      {
        "matcher": "Bash|Glob|Grep|Read|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/scout-block.cjs",
            "_origin": "engineer"
          },
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/privacy-block.cjs",
            "_origin": "engineer"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/format-on-stop.sh"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/ensure-task-complete.sh",
            "timeout": 30
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/session-state.cjs",
            "_origin": "engineer"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/subagent-init.cjs",
            "_origin": "engineer"
          },
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/team-context-inject.cjs",
            "_origin": "engineer"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "Plan",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/cook-after-plan-reminder.cjs",
            "_origin": "engineer"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/session-state.cjs",
            "_origin": "engineer"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/dev-rules-reminder.cjs",
            "_origin": "engineer"
          },
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/simplify-gate.cjs",
            "_origin": "engineer"
          },
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/usage-quota-cache-refresh.cjs",
            "timeout": 30,
            "_origin": "engineer"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Task|TaskCreate|TaskUpdate|TodoWrite",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/session-state.cjs",
            "_origin": "engineer"
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/plan-format-kanban.cjs",
            "_origin": "engineer"
          }
        ]
      },
      {
        "matcher": "Bash|Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/usage-quota-cache-refresh.cjs",
            "timeout": 10,
            "_origin": "engineer"
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/task-completed-handler.cjs"
          }
        ]
      }
    ],
    "TeammateIdle": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/teammate-idle-handler.cjs"
          }
        ]
      }
    ]
  },
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "statusLine": {
    "type": "command",
    "command": "node \"$CLAUDE_PROJECT_DIR\"/.claude/statusline.cjs",
    "padding": 0
  }
}
